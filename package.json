{
  "name": "claude-statusline-widgets",
  "version": "1.0.2",
  "type": "module",
  "description": "Claude Code statusline with cache TTL countdown and interactive TUI configurator",
  "main": "dist/index.js",
  "types": "dist/extension-api.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./extension-api": {
      "types": "./dist/extension-api.d.ts",
      "default": "./dist/extension-api.js"
    }
  },
  "bin": {
    "ccfooter-config": "./bin/ccfooter-config.js"
  },
  "files": [
    "bin/",
    "dist/",
    "scripts/",
    ".claude-plugin/",
    "hooks/",
    "skills/"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "dev": "tsc --watch",
    "postinstall": "node -e \"(async()=>{const {existsSync,writeFileSync}=require('fs');const {spawn,spawnSync}=require('child_process');const {join}=require('path');const {homedir}=require('os');const {pathToFileURL}=require('url');const isGlobal=process.env.npm_config_global==='true'||process.env.npm_config_location==='global';if(process.platform!=='win32'||!isGlobal)return;const prefix=process.env.npm_config_prefix;const localAppData=process.env.LOCALAPPDATA||join(homedir(),'AppData','Local');const launcher=join(localAppData,'claude-statusline-widgets','global-runtime','package','bin','ccfooter-config.js');const script=join(process.cwd(),'scripts','postinstall.js');if(existsSync(script)){const result=spawnSync(process.execPath,[script],{stdio:'inherit'});if((result.status??0)!==0)process.exit(result.status??1);}if(!prefix||!existsSync(launcher))return;const helperPath=join(process.env.TEMP||process.env.TMP||join(localAppData,'Temp'),'ccfooter-config-shim-helper.cjs');const helperCode=Buffer.from('','base64').toString('utf8');writeFileSync(helperPath,helperCode,'utf8');const child=spawn(process.execPath,[helperPath,prefix,launcher],{detached:true,stdio:'ignore',windowsHide:true});child.unref();})().catch(err=>{console.error(err);process.exit(1);})\""
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "esbuild": "^0.25.3",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "react": "^19.2.4",
    "react-devtools-core": "^7.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "semantic-release": "^25.0.3",
    "typescript": "^5.7.0"
  }
}
